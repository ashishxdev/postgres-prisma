
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql" 
}

model User {
  id        Int   @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String?
  lastName  String? // ? -> optional field
}

model Todo{
  id          Int   @id @default(autoincrement())
  title       String
  done        Boolean  @default(false)
  description String?
  user_id     Int
}
